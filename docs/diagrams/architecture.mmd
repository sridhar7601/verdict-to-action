flowchart TB
    subgraph Input["INPUT"]
      PDF["Court Judgment PDF<br/>(typed or scanned)"]
    end
    subgraph Extract["EXTRACTION PIPELINE"]
      PARSE["PDF Text Extractor<br/>(pdf-parse)"]
      AI["AI Action Plan Extractor<br/>• parties<br/>• obligations<br/>• deadlines<br/>• responsible parties<br/>• verbatim source excerpts"]
      DEADLINE["Deadline Parser<br/>('within 90 days'<br/>→ ISO date)"]
    end
    subgraph Store["STRUCTURED STORE"]
      DB[("SQLite + Prisma<br/>judgments • parties<br/>obligations • updates")]
    end
    subgraph UI["GOVERNMENT EXECUTOR DASHBOARD"]
      DASH["Obligation Tracker<br/>(priority · status · deadline)"]
      VERIFY["Verification Workflow<br/>(source excerpt traceable)"]
      CAL["Deadline Calendar<br/>+ overdue alerts"]
    end
    PDF --> PARSE --> AI
    AI --> DEADLINE
    AI --> DB
    DEADLINE --> DB
    DB --> DASH & VERIFY & CAL
